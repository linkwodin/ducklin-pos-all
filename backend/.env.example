# JWT token lifetime in hours (default 24). Management UI auto-refreshes while you work.
# JWT_EXPIRATION=24
STORAGE_PROVIDER=gcp
GCP_BUCKET_NAME=your-gcp-bucket-name
AWS_S3_BUCKET=your-aws-s3-bucket
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=us-east-1
ENVIRONMENT=development
PORT=8080
PDF_FONT_PATH=uploads/assets/fonts/NotoSansTC-Regular.ttf

# Gmail / Google Workspace SMTP (same as Cloud Run UAT — copy from Secret Manager or Console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587   # STARTTLS (default on Cloud Run UAT)
# SMTP_PORT=465   # implicit TLS — try locally if 587 is blocked by ISP/firewall
# SMTP_USER=you@yourdomain.co.uk
# SMTP_PASSWORD=your-google-app-password
# SMTP_FROM=no-reply@yourdomain.co.uk
# Logo for PDF header (default: uploads/assets/images/pdf_logo.png)
# PDF_LOGO_PATH=uploads/assets/images/pdf_logo.png
