# Local one-click install — copied to backend/.env by INSTALL-LOCAL.sh / INSTALL-LOCAL.bat
DATABASE_URL=mysql://pos_user:pos_local_pass@127.0.0.1:3306/pos_system
JWT_SECRET=change-me-after-install
ENVIRONMENT=development
PORT=8868
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:8868
PDF_LOGO_PATH=uploads/assets/images/pdf_logo.png

# Default admin created by: go run ./cmd/seed-local (override before seed if desired)
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=admin123
# SEED_ADMIN_PIN=1234
