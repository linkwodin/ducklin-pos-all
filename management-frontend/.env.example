# Go management API (Vite dev proxy uses /api → see vite.config)
# VITE_API_URL=/api/v1

# Authenticated Cloud Function URL for internal AI playbook (GET + Bearer JWT).
# Required for production builds. For `npm run dev`, omit this — playbook loads from ../docs/.
# VITE_AI_PLAYBOOK_URL=https://<region>-<project>.cloudfunctions.net/aiPlaybook
